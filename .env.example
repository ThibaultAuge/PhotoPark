# Copy this file to .env and fill it with production values.
# Generate APP_PASSWORD_HASH with:
# npm run hash-password -- "your-strong-password"
APP_PASSWORD_HASH="pbkdf2:sha256:310000:replace-salt:replace-hash"

# Required. Use at least 32 random characters.
SESSION_SECRET="replace-with-at-least-32-random-bytes"

# SQLite database path. Keep it outside public folders and out of git.
DATABASE_PATH="./data/photos.sqlite"

# Public client-side value used to compute APS-C equivalents.
NEXT_PUBLIC_APSC_CROP_FACTOR="1.5"

# Set to true only if a trusted reverse proxy overwrites X-Forwarded-For.
TRUST_PROXY="false"
